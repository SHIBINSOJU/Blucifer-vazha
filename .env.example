# Discord Bot Token
# Get this from https://discord.com/developers/applications
TOKEN=your_bot_token_here

# Client ID (Application ID)
# Get this from https://discord.com/developers/applications → Your App → General Information
CLIENT_ID=your_client_id_here

# Guild ID (Server ID) - For testing slash commands
# Right-click your server → Copy Server ID (requires Developer Mode enabled)
GUILD_ID=your_guild_id_here

# Welcome Channel ID (where welcome messages are sent)
WELCOME_CHANNEL_ID=your_welcome_channel_id

# Rules Channel ID (for the rules button)
RULES_CHANNEL_ID=your_rules_channel_id

# Auto Role ID (role given to new members)
AUTO_ROLE_ID=your_auto_role_id

# Say Command Role ID (who can use !say command)
SAY_ROLE_ID=your_say_role_id

# Note: AutoMod settings are now managed via the !automod command
# and stored in the database (data/bot.db)
# 
# Required Bot Permissions:
# - Manage Messages (for AutoMod message deletion)
# - Manage Roles (for mute/unmute)
# - Kick Members
# - Ban Members
# - View Audit Log (optional, for better logging)
# - Send Messages
# - Embed Links
# - Attach Files
# - Read Message History
# - Use Application Commands (for slash commands)
